# --- Secrets (required; leave blank here, set real values in .env) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=

# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://briefr:briefr@localhost:5433/briefr
REDIS_URL=redis://localhost:6379
CHROMA_HOST=localhost
CHROMA_PORT=8001

# development | production. In production the app fail-fasts on a missing
# API_KEY, missing service keys, or a wildcard CORS policy (see config.py).
ENVIRONMENT=development

# --- API authentication (P0.1) ---
# Shared secret required in the X-API-Key header on every API endpoint. Blank
# disables auth (development only); REQUIRED when ENVIRONMENT != development.
API_KEY=

# --- CORS (P0.3) ---
# Comma-separated origin allowlist. '*' is allowed only in development; in
# production set explicit origins, e.g. https://app.example.com
CORS_ORIGINS=*

# --- Rate limiting & spend controls (P0.2) ---
# RATE_LIMIT applies per identity to every endpoint. MAX_CONCURRENT_BRIEFS caps
# in-flight briefs globally; DAILY_BRIEF_LIMIT caps briefs per UTC day. 0 = off.
RATE_LIMIT=60/minute
MAX_CONCURRENT_BRIEFS=5
DAILY_BRIEF_LIMIT=200

# --- Upload hardening (P0.4) ---
MAX_UPLOAD_BYTES=10485760
MAX_PDF_PAGES=200

# --- Chroma auth (P0.6; production) ---
# Bearer token the client sends to the Chroma server. Blank = no auth (dev).
CHROMA_AUTH_TOKEN=
